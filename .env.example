# causal-worlds — copy to `.env` and fill in your keys. `.env` is gitignored; never commit real keys.
# The CLI auto-loads `.env` (via python-dotenv); the provider SDKs read these standard env vars.
# The base install needs NONE of these — they're only for the optional extras below.

# --- LLM authoring (`pip install 'causal-worlds[llm]'`) -----------------------------------------
# Claude authors worlds; Gemini is the independent judge (must be a different model family).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
GEMINI_API_KEY=xxxxxxxx

# --- Observability / tracing (`pip install 'causal-worlds[observability]'`) ----------------------
# Langfuse traces the author -> gate -> admit pipeline so you can see each run.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com   # EU cloud; US: https://us.cloud.langfuse.com (alias: LANGFUSE_BASE_URL)

# --- Package settings (pydantic-settings; prefix CAUSAL_WORLDS_) ---------------------------------
CAUSAL_WORLDS_LANGFUSE_ENABLED=true        # turn Langfuse tracing on (off by default)
# CAUSAL_WORLDS_AUTHOR_MODEL=claude-opus-4-8
# CAUSAL_WORLDS_JUDGE_MODEL=gemini-2.5-flash
# CAUSAL_WORLDS_DISCOVERER_N=8000
# CAUSAL_WORLDS_SEED=0

# --- Publishing (maintainers only; not needed to use the package) --------------------------------
# PYPI_TOKEN=pypi-xxxxxxxx
